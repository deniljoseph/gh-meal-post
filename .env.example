# Copy this to .env for local development
# On Railway, set these in the Variables tab

# PostgreSQL connection string (Railway sets this automatically when you add a Postgres plugin)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secret - change this to a long random string in production!
SECRET_KEY=change-this-to-a-long-random-secret-key

# Port (Railway sets this automatically)
# PORT=8000

# ── OPTIONAL: Email delivery for scheduled daily backups ──────────────────────
# If these are not set, backups still run automatically and are stored/downloadable
# in-app under Settings — they just won't be emailed anywhere.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password
# BACKUP_EMAIL_TO=admin@geometryhome.com
